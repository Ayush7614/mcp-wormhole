{
  "name": "@mcp-wormhole/vercel",
  "version": "0.2.0",
  "description": "MCP server for Vercel — 18 tools, 8 prompt workflows, and browsable vercel:// resources via the Vercel REST API.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-wormhole-vercel": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/chunk-*.js",
    "dist/chunk-*.js.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "verify": "node --env-file=.env dist/verify.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "vercel", "deployments", "devops", "model-context-protocol"],
  "license": "MIT",
  "author": "Ayush Kumar <ayushknj3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ayush7614/mcp-wormhole.git",
    "directory": "packages/vercel"
  },
  "homepage": "https://github.com/Ayush7614/mcp-wormhole/tree/master/packages/vercel#readme",
  "bugs": {
    "url": "https://github.com/Ayush7614/mcp-wormhole/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
